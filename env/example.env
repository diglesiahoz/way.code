# APPSETTING_DEV: 
#  - Determina si establecer el entorno en modo desarrollo.
#  - Usado para hacer hot-reload de la documentación si se está en modo desarrollo.
APPSETTING_DEV=false

# APPSETTING_SOURCE_IMAGE: 
#  - Determina la imagen del entorno
APPSETTING_SOURCE_IMAGE=ubuntu:24.04

# APPSETTING_PROJECTS_PATH:
#  - Establece la ruta en donde están creados tus proyectos y será montada dentro del contenedor.
#  - Es importante que aquellos proyectos que necesites gestionar con la aplicación, estén alojados en el mismo directorio.
APPSETTING_PROJECTS_PATH=/home/${USER}/project
